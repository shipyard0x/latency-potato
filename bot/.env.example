# NEVER commit your real .env. Use a burner wallet funded only with what
# you are willing to lose.
PRIVATE_KEY=0xYOUR_BURNER_WALLET_PRIVATE_KEY
GAME_ADDRESS=0xDEPLOYED_LATENCY_POTATO_ADDRESS
RPC_URL=https://rpc.mainnet.chain.robinhood.com
FEED_WS=wss://feed.mainnet.chain.robinhood.com
# Fire this many ms BEFORE roundEndTime (default 150)
FIRE_BEFORE_MS=150
# Max ETH price you'll pay for the potato (circuit breaker)
MAX_PRICE_ETH=0.1
