# ============ REQUIRED ============
# Deployer wallet private key. Fund with a small amount of ETH for gas only.
PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY

# Fee receivers (can both be your wallet)
PROTOCOL_TREASURY=0xYOUR_WALLET   # gets 2% of every steal
DEV_TREASURY=0xYOUR_WALLET       # gets 10% of every settled jackpot

# ============ LAUNCHPAD MODE ============
# Your $POTATO contract address from the launchpad. If set, deploy script
# skips deploying our token and wires the game to this CA.
TOKEN_CA=

# ============ OPTIONAL ============
RPC_URL=https://rpc.mainnet.chain.robinhood.com
# Fallback POTATO-per-ETH rate in wei (default 1M/ETH). Set honestly —
# this prices the 5%-discount token payment path until the TWAP oracle is live.
POTATO_PER_ETH=
